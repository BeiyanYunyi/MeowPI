{
  "name": "meow-pi",
  "type": "module",
  "version": "0.5.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "description": "Meow Personality Inventory",
  "author": {
    "name": "BeiyanYunyi",
    "email": "beiyanyunyi@oneamongus.ca",
    "url": "https://github.com/BeiyanYunyi"
  },
  "license": "AGPL-3.0-or-later",
  "repository": {
    "url": "https://github.com/BeiyanYunyi/MeowPI"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./aio": {
      "types": "./dist/aio.d.ts",
      "import": "./dist/aio.js",
      "require": "./dist/aio.umd.cjs",
      "default": "./dist/aio.umd.cjs"
    },
    "./component": {
      "types": "./dist/App.vue.d.ts",
      "import": "./dist/App.vue",
      "require": "./dist/App.vue",
      "default": "./dist/App.vue"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "main": "dist/index.umd.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:server": "pnpm -F server run dev",
    "build": "vite build && vue-tsc --noEmit",
    "preview": "pnpm build && wrangler dev",
    "lint": "eslint --cache .",
    "test": "pnpm exec tsx --test tests/**/*.test.ts",
    "deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "fflate": "^0.8.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@cloudflare/vite-plugin": "^1.30.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@iconify-json/octicon": "^1.2.22",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@stylexjs/stylex": "^0.18.2",
    "@stylexjs/unplugin": "^0.18.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vueuse/core": "^14.2.1",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^2.0.1",
    "lightningcss": "^1.32.0",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-bundle-analyzer": "^1.3.6",
    "vue-macros": "^3.0.0",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.78.0"
  },
  "pnpm": {
    "overrides": {
      "array-includes": "npm:@nolyfill/array-includes@^1",
      "array.prototype.findlastindex": "npm:@nolyfill/array.prototype.findlastindex@^1",
      "array.prototype.flat": "npm:@nolyfill/array.prototype.flat@^1",
      "array.prototype.flatmap": "npm:@nolyfill/array.prototype.flatmap@^1",
      "hasown": "npm:@nolyfill/hasown@^1",
      "is-core-module": "npm:@nolyfill/is-core-module@^1",
      "object.assign": "npm:@nolyfill/object.assign@^1",
      "object.entries": "npm:@nolyfill/object.entries@^1",
      "object.fromentries": "npm:@nolyfill/object.fromentries@^1",
      "object.groupby": "npm:@nolyfill/object.groupby@^1",
      "object.values": "npm:@nolyfill/object.values@^1",
      "safer-buffer": "npm:@nolyfill/safer-buffer@^1"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "simple-git-hooks",
      "workerd"
    ],
    "patchedDependencies": {
      "@stylexjs/unplugin": "patches/@stylexjs__unplugin.patch"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint --edit $1"
  },
  "lint-staged": {
    "*": [
      "eslint"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
