{
  "name": "meow-pi",
  "type": "module",
  "version": "0.5.0",
  "packageManager": "pnpm@10.5.2+sha512.da9dc28cd3ff40d0592188235ab25d3202add8a207afbedc682220e4a0029ffbff4562102b9e6e46b4e3f9e8bd53e6d05de48544b0c57d4b0179e22c76d1199b",
  "description": "Meow Personality Inventory",
  "author": {
    "name": "BeiyanYunyi",
    "email": "beiyanyunyi@oneamongus.ca",
    "url": "https://github.com/BeiyanYunyi"
  },
  "license": "AGPL-3.0-or-later",
  "repository": {
    "url": "https://github.com/BeiyanYunyi/MeowPI"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./aio": {
      "types": "./dist/aio.d.ts",
      "import": "./dist/aio.js",
      "require": "./dist/aio.umd.cjs",
      "default": "./dist/aio.umd.cjs"
    },
    "./component": {
      "types": "./dist/App.vue.d.ts",
      "import": "./dist/App.vue",
      "require": "./dist/App.vue",
      "default": "./dist/App.vue"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "main": "dist/index.umd.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:server": "pnpm -F server run dev",
    "build": "vite build && vue-tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint --cache ."
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.4.0",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@iconify-json/octicon": "^1.2.5",
    "@iconify-json/svg-spinners": "^1.2.2",
    "@stylex-extend/core": "^0.7.1",
    "@stylex-extend/vite": "^0.7.1",
    "@stylexjs/stylex": "^0.11.1",
    "@types/node": "^22.13.9",
    "@unocss/eslint-plugin": "^66.0.0",
    "@unocss/reset": "^66.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vueuse/core": "^12.7.0",
    "eslint": "^9.21.0",
    "eslint-plugin-format": "^1.0.1",
    "lightningcss": "^1.29.1",
    "lint-staged": "^15.4.3",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "unocss": "^66.0.0",
    "unplugin-vue-macros": "^2.14.5",
    "unplugin-vue-router": "^0.12.0",
    "vite": "^6.2.0",
    "vite-bundle-analyzer": "^0.17.1",
    "vue-tsc": "^2.2.8"
  },
  "pnpm": {
    "overrides": {
      "array-includes": "npm:@nolyfill/array-includes@^1",
      "array.prototype.findlastindex": "npm:@nolyfill/array.prototype.findlastindex@^1",
      "array.prototype.flat": "npm:@nolyfill/array.prototype.flat@^1",
      "array.prototype.flatmap": "npm:@nolyfill/array.prototype.flatmap@^1",
      "hasown": "npm:@nolyfill/hasown@^1",
      "is-core-module": "npm:@nolyfill/is-core-module@^1",
      "object.assign": "npm:@nolyfill/object.assign@^1",
      "object.entries": "npm:@nolyfill/object.entries@^1",
      "object.fromentries": "npm:@nolyfill/object.fromentries@^1",
      "object.groupby": "npm:@nolyfill/object.groupby@^1",
      "object.values": "npm:@nolyfill/object.values@^1"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks",
      "workerd"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint --edit $1"
  },
  "lint-staged": {
    "*": [
      "eslint"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
